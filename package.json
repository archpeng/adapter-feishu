{
  "name": "adapter-feishu",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Standalone Feishu/Lark adapter scaffold with provider-neutral core contracts.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "smoke:provider-webhook": "node scripts/smoke-provider-webhook.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run build && npm run test"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
