# standalone host
ADAPTER_FEISHU_HOST=0.0.0.0
ADAPTER_FEISHU_PORT=8787
ADAPTER_FEISHU_PUBLIC_BASE_URL=http://localhost:8787

# ingress mode
FEISHU_INGRESS_MODE=webhook

# Feishu app credentials
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=app_secret_xxx
FEISHU_WEBHOOK_VERIFICATION_TOKEN=
FEISHU_WEBHOOK_SECRET=
FEISHU_ENCRYPT_KEY=

# provider routing baseline
# enable PMS checkout by setting: ADAPTER_FEISHU_PROVIDER_KEYS=warning-agent,pms-checkout
# keep defaultProvider on warning-agent unless this adapter instance is dedicated to PMS checkout
# set ADAPTER_FEISHU_ALLOW_PROVIDER_OVERRIDE=true when multiple provider keys are enabled and callers send explicit providerKey
ADAPTER_FEISHU_PROVIDER_KEYS=warning-agent
ADAPTER_FEISHU_DEFAULT_PROVIDER=warning-agent
ADAPTER_FEISHU_ALLOW_PROVIDER_OVERRIDE=false
ADAPTER_FEISHU_PROVIDER_WEBHOOK_AUTH_TOKEN=

# form webhook / existing Base table record-write baseline
# keep this auth separate from ADAPTER_FEISHU_PROVIDER_WEBHOOK_AUTH_TOKEN
ADAPTER_FEISHU_FORM_WEBHOOK_AUTH_TOKEN=
ADAPTER_FEISHU_FORM_ALLOW_TARGET_OVERRIDE=false
ADAPTER_FEISHU_FORM_USER_ID_TYPE=user_id
# set APP_TOKEN + TABLE_ID together; FORM_ID is optional unless validateFormSchema=true for the default target
ADAPTER_FEISHU_FORM_DEFAULT_APP_TOKEN=
ADAPTER_FEISHU_FORM_DEFAULT_TABLE_ID=
ADAPTER_FEISHU_FORM_DEFAULT_FORM_ID=
# optional managed form registry file; unset keeps /providers/form-webhook in legacy-only/default-target mode
# for local managed-mode startup, copy/edit config/form-bindings.example.json with real tenant target IDs, then set:
# ADAPTER_FEISHU_FORM_REGISTRY_PATH=config/form-bindings.example.json
ADAPTER_FEISHU_FORM_REGISTRY_PATH=

# bounded short-lived state
ADAPTER_FEISHU_DEDUPE_TTL_SECONDS=300
ADAPTER_FEISHU_PENDING_TTL_SECONDS=900
# optional durable pending action file for restart-safe card callbacks; use a local/mounted path, not git
ADAPTER_FEISHU_PENDING_STATE_PATH=

# PMS checkout callback forwarding to ai-pms/Hermes orchestrator
# URL is local/non-secret; token value must come from local env and must not be committed
ADAPTER_FEISHU_PMS_CHECKOUT_CALLBACK_URL=
ADAPTER_FEISHU_PMS_CHECKOUT_CALLBACK_TIMEOUT_MS=5000
AI_PMS_CALLBACK_TOKEN=

# optional smoke-test target for npm run smoke:provider-webhook
ADAPTER_FEISHU_SMOKE_BASE_URL=http://127.0.0.1:8787
ADAPTER_FEISHU_SMOKE_CHAT_ID=
ADAPTER_FEISHU_SMOKE_OPEN_ID=
